<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.yiguardsilverfa.dao.LoginDAO">

    <resultMap id="UserMap" type="com.yiguardsilverfa.entity.User">
        <id column="id" property="id"/>
        <result column="username" property="username"/>
        <result column="email" property="email"/>
        <result column="password" property="password"/>
        <result column="nickname" property="nickname"/>
        <result column="phone" property="phone"/>
        <result column="role" property="role"/>
        <result column="avatar" property="avatar"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <insert id="insertUser" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO sys_user (username, email, password, nickname, phone, role, status, create_time, update_time)
        VALUES (#{username}, #{email}, #{password}, #{nickname}, #{phone}, #{role}, #{status}, NOW(), NOW())
    </insert>

    <select id="selectUserByUsername" resultMap="UserMap">
        SELECT * FROM sys_user WHERE username = #{username}
    </select>

    <select id="selectUserByEmail" resultMap="UserMap">
        SELECT * FROM sys_user WHERE email = #{email}
    </select>

    <select id="selectUserById" resultMap="UserMap">
        SELECT * FROM sys_user WHERE id = #{id}
    </select>
    <!-- 根据手机号查询 -->
    <select id="selectUserByPhone" resultMap="UserMap">
        SELECT * FROM sys_user WHERE phone = #{phone}
    </select>
    <!-- 动态更新：只更新非空字段 -->
    <update id="updateUserSelective" parameterType="com.yiguardsilverfa.entity.User">
        UPDATE sys_user
        <set>
            <if test="nickname != null">nickname = #{nickname},</if>
            <if test="phone != null">phone = #{phone},</if>
            <if test="email != null">email = #{email},</if>
            <if test="avatar != null">avatar = #{avatar},</if>
            update_time = NOW()
        </set>
        WHERE id = #{id}
    </update>
    <!-- 逻辑删除用户 -->
    <update id="logout">
        UPDATE sys_user
        SET status = 0, update_time = NOW()
        WHERE id = #{userId}
    </update>
    <!-- 删除家属绑定-->
    <update id="deleteFamilybind">
        update family_bind
        SET status = 0
        WHERE family_user_id = #{userId}
    </update>

    <update id="updateUserById">
        UPDATE sys_user
        <set>
            <if test="password != null">password = #{password},</if>
            <if test="phone != null">phone = #{phone},</if>
            <if test="nickname != null">nickname = #{nickname},</if>
            <if test="avatar != null">avatar = #{avatar},</if>
            <if test="status != null">status = #{status},</if>
            update_time = NOW()
        </set>
        WHERE id = #{id}
    </update>

    <update id="updateUserByUsername">
        UPDATE sys_user
        SET password = #{password}, update_time = NOW()
        WHERE username = #{username}
    </update>

    <select id="checkUsernameExists" resultType="int">
        SELECT COUNT(*) FROM sys_user WHERE username = #{username}
    </select>

    <select id="checkEmailExists" resultType="int">
        SELECT COUNT(*) FROM sys_user WHERE email = #{email}
    </select>
</mapper>