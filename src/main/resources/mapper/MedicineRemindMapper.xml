<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" 
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.yiguardsilverfa.dao.MedicineRemindDAO">
    <resultMap id="BaseResultMap" type="com.yiguardsilverfa.entity.MedicineRemind">
        <id column="id" property="id"/>
        <result column="elder_id" property="elderId"/>
        <result column="medicine_name" property="medicineName"/>
        <result column="dosage" property="dosage"/>
        <result column="usage" property="usage"/>
        <result column="remind_time" property="remindTime"/>
        <result column="remind_days" property="remindDays"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>
<!--带老人姓名的 resultMap-->
    <resultMap id="WithNameResultMap" type="com.yiguardsilverfa.dto.medicineRemind.MedicineRemindWithNameDTO" extends="BaseResultMap">
        <result column="elder_name" property="elderName"/>
    </resultMap>

    <!--增加提醒-->
    <insert id="insertMedicineRemind" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO medicine_remind (elder_id, medicine_name, dosage, `usage`, remind_time, remind_days, status, create_time, update_time)
        VALUES (#{elderId}, #{medicineName}, #{dosage}, #{usage}, #{remindTime}, #{remindDays}, 1, NOW(), NOW())
    </insert>

    <!--修改提醒-->
    <update id="updateMedicineRemind">
        UPDATE medicine_remind
        <set>
            <if test="medicineName != null">medicine_name = #{medicineName},</if>
            <if test="dosage != null">dosage = #{dosage},</if>
            <if test="usage != null">`usage` = #{usage},</if>
            <if test="remindTime != null">remind_time = #{remindTime},</if>
            <if test="remindDays != null">remind_days = #{remindDays},</if>
            <if test="status != null">status = #{status},</if>
            update_time = NOW()
        </set>
        WHERE id = #{id}
    </update>

    <!--删除提醒-->
    <delete id="deleteMedicineRemind">
        DELETE FROM medicine_remind WHERE id = #{id}
    </delete>
    <!--通过提醒id查找-->
    <select id="selectById" resultMap="BaseResultMap">
        SELECT * FROM medicine_remind WHERE id = #{id}
    </select>
    <!--通过老人id查找-->
    <select id="selectByElderId" resultMap="BaseResultMap">
        SELECT * FROM medicine_remind WHERE elder_id = #{elderId} ORDER BY remind_time
    </select>

    <!-- 根据单个档案ID查询（带老人姓名） -->
    <select id="selectWithNameByElderId" resultMap="WithNameResultMap">
        SELECT mr.*,
               COALESCE(ei.elder_name,u.username) AS elder_name
        FROM medicine_remind mr
                 JOIN elder_info ei ON mr.elder_id = ei.id
                 LEFT JOIN sys_user u ON ei.user_id = u.id
        WHERE mr.elder_id = #{elderId}
        ORDER BY mr.remind_time
    </select>
    <!-- 根据提醒ID查询（带老人姓名） -->
    <select id="selectWithNameById" resultMap="WithNameResultMap">
        SELECT mr.*,
               COALESCE(ei.elder_name,u.username) AS elder_name
        FROM medicine_remind mr
                 JOIN elder_info ei ON mr.elder_id = ei.id
                 LEFT JOIN sys_user u ON ei.user_id = u.id
        WHERE mr.id = #{id}
    </select>
</mapper>


