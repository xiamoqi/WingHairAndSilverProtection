<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.yifasilverguard.dao.LoginDAO">

    <resultMap id="UserMap" type="com.yifasilverguard.entity.User">
        <id column="id" property="id"/>
        <result column="username" property="username"/>
        <result column="email" property="email"/>
        <result column="password" property="password"/>
        <result column="nickname" property="nickname"/>
        <result column="phone" property="phone"/>
        <result column="phone_bound" property="phoneBound"/>
        <result column="role" property="role"/>
        <result column="avatar" property="avatar"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <insert id="insertUser" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO sys_user (username, email, password, nickname, phone, phone_bound, role, status, create_time, update_time)
        VALUES (#{username}, #{email}, #{password}, #{nickname}, #{phone}, #{phoneBound}, #{role}, #{status}, NOW(), NOW())
    </insert>

    <select id="selectUserByUsername" resultMap="UserMap">
        SELECT * FROM sys_user WHERE username = #{username}
    </select>

    <select id="selectUserByEmail" resultMap="UserMap">
        SELECT * FROM sys_user WHERE email = #{email}
    </select>

    <select id="selectUserById" resultMap="UserMap">
        SELECT * FROM sys_user WHERE id = #{id}
    </select>

    <update id="updateUserById">
        UPDATE sys_user
        <set>
            <if test="password != null">password = #{password},</if>
            <if test="phone != null">phone = #{phone},</if>
            <if test="phoneBound != null">phone_bound = #{phoneBound},</if>
            <if test="nickname != null">nickname = #{nickname},</if>
            <if test="avatar != null">avatar = #{avatar},</if>
            <if test="status != null">status = #{status},</if>
            update_time = NOW()
        </set>
        WHERE id = #{id}
    </update>

    <update id="updateUserByUsername">
        UPDATE sys_user
        SET password = #{password}, update_time = NOW()
        WHERE username = #{username}
    </update>

    <select id="checkUsernameExists" resultType="int">
        SELECT COUNT(*) FROM sys_user WHERE username = #{username}
    </select>

    <select id="checkEmailExists" resultType="int">
        SELECT COUNT(*) FROM sys_user WHERE email = #{email}
    </select>

    <update id="bindPhone">
        UPDATE sys_user SET phone = #{phone}, phone_bound = 1, update_time = NOW()
        WHERE id = #{userId}
    </update>

</mapper>